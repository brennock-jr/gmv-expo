rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Função auxiliar para verificar se o usuário autenticado é um administrador
    function isAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'administrador';
    }
    
    // Coleção de usuários (Perfis e Prontuários Médicos)
    match /users/{userId} {
      // Qualquer operador autenticado lê seu próprio perfil. Admins lêem todos.
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      
      // Permitir auto-cadastro no registro (inicialmente como voluntário pendente)
      allow create: if request.auth != null && request.auth.uid == userId 
        && request.resource.data.role == 'voluntario' 
        && request.resource.data.approved == false;
        
      // Atualização de perfil/ficha médica
      allow update: if request.auth != null && (
        // Administrador pode alterar qualquer campo (ex: aprovar operador)
        isAdmin() || 
        // O voluntário pode atualizar sua ficha, mas NÃO pode alterar seu cargo ou status de aprovação
        (request.auth.uid == userId 
         && request.resource.data.role == resource.data.role 
         && request.resource.data.approved == resource.data.approved)
      );
      
      // Apenas administradores podem excluir perfis
      allow delete: if isAdmin();
    }
    
    // Coleção de Missões
    match /missions/{missionId} {
      // Apenas operadores aprovados ou administradores podem ver as missões
      allow read: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.approved == true || isAdmin()
      );
      
      // Apenas administradores criam ou excluem missões
      allow create, delete: if isAdmin();
      
      // Atualização de missão
      allow update: if request.auth != null && (
        // Admin pode alterar tudo
        isAdmin() ||
        // Voluntário aprovado pode apenas atualizar seu alistamento (adicionando/removendo a si mesmo no array de participants)
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.approved == true 
         && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['participants'])
         && (
           request.resource.data.participants.difference(resource.data.participants).hasOnly([request.auth.uid]) ||
           resource.data.participants.difference(request.resource.data.participants).hasOnly([request.auth.uid])
         )
        )
      );
      
      // Subcoleção de Inscrições (enrollments)
      match /enrollments/{userId} {
        // Leitura: O próprio usuário ou administradores
        allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
        
        // Escrita: Administradores ou o próprio voluntário (se aprovado)
        allow write: if request.auth != null && (
          isAdmin() ||
          (request.auth.uid == userId && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.approved == true)
        );
      }
    }
  }
}
